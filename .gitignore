# ===================================
# FLIGHT BOOKING SYSTEM - .gitignore
# ===================================

# ============================================
# CRITICAL - NEVER COMMIT THESE FILES
# ============================================

# Environment Variables (Contains sensitive credentials)
.env
.env.local
.env.development
.env.test
.env.production
.env.*.local
backend/.env
backend/.env.local
backend/.env.development
backend/.env.production

# ============================================
# Dependencies
# ============================================

# Node modules
node_modules/
backend/node_modules/
frontend/node_modules/
*/node_modules/

# Package lock files (optional - uncomment if you want to ignore)
# package-lock.json
# backend/package-lock.json
# yarn.lock
# pnpm-lock.yaml

# ============================================
# Build Output
# ============================================

# Vite build output
dist/
dist-ssr/
build/
.vite/

# Production build
/build
/dist

# ============================================
# Logs
# ============================================

# Log files
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Runtime logs
*.log.*
combined.log
error.log
access.log

# ============================================
# Testing
# ============================================

# Test coverage
coverage/
.nyc_output/
*.lcov

# Test results
test-results/
junit.xml

# ============================================
# Temporary Files
# ============================================

# Temporary files
*.tmp
*.temp
.cache/
.temp/
tmp/

# Swap files
*.swp
*.swo
*~

# ============================================
# Operating System Files
# ============================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory
.Trash-*

# ============================================
# IDE & Editor Files
# ============================================

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# JetBrains IDEs (WebStorm, IntelliJ, etc.)
.idea/
*.iml
*.iws
*.ipr
.idea_modules/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p]

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc

# ============================================
# Database Files
# ============================================

# Local database files
*.sqlite
*.sqlite3
*.db
*.db-journal

# MongoDB local
data/
mongodb/

# ============================================
# Upload & Media Files
# ============================================

# Uploaded files (if you have file uploads)
uploads/
backend/uploads/
public/uploads/

# User generated content
user-content/
media/

# ============================================
# Security & Credentials
# ============================================

# SSL certificates
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx

# SSH keys
id_rsa
id_rsa.pub
*.ppk

# API keys and secrets
secrets/
.secrets/
credentials.json
service-account.json

# ============================================
# Development & Debug
# ============================================

# Debug files
debug/
.debug/
*.debug

# Source maps (optional - uncomment to ignore)
# *.map
# *.js.map

# ============================================
# Miscellaneous
# ============================================

# Local configuration
.local
*.local

# Backup files
*.bak
*.backup
*.old
*_backup
*_old

# Archive files
*.zip
*.tar
*.tar.gz
*.rar
*.7z

# Documentation build
docs/_build/
site/

# ============================================
# Project Specific
# ============================================

# Test files (keep test scripts but ignore results)
backend/test-email.js
EMAIL_TEST_RESULTS.txt

# Temporary documentation
CLEANUP_SUMMARY.txt
EMAIL_SETUP_SUMMARY.txt
FINAL_SETUP_STATUS.txt

# ============================================
# Optional - Uncomment if needed
# ============================================

# If you want to ignore all markdown files except README
# *.md
# !README.md

# If you want to ignore all JSON except package.json
# *.json
# !package.json
# !tsconfig.json

# ============================================
# IMPORTANT NOTES:
# ============================================
# 
# 1. NEVER commit .env files - they contain sensitive credentials
# 2. NEVER commit node_modules - they can be reinstalled
# 3. NEVER commit API keys, passwords, or secrets
# 4. Always review files before committing
# 5. Use 'git status' to check what will be committed
# 
# To check if sensitive files are tracked:
#   git ls-files | grep -E '\.env|credentials|secrets'
# 
# To remove accidentally committed .env file:
#   git rm --cached backend/.env
#   git commit -m "Remove .env file"
# 
# ============================================
