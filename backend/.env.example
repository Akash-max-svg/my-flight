# ===================================
# BACKEND ENVIRONMENT VARIABLES
# ===================================

# Server Configuration
PORT=5000
NODE_ENV=development

# ===================================
# MongoDB Configuration
# ===================================
# Get your connection string from MongoDB Atlas:
# 1. Go to https://cloud.mongodb.com
# 2. Click "Connect" on your cluster
# 3. Choose "Connect your application"
# 4. Copy the connection string
# 5. Replace <username>, <password>, and database name

MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/<database>?retryWrites=true&w=majority

# ===================================
# JWT Configuration
# ===================================
# Generate secure random strings for production:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your-refresh-token-secret-change-this-in-production
JWT_REFRESH_EXPIRE=30d

# ===================================
# Email Configuration (Gmail SMTP)
# ===================================
# OPTIONAL - For email notifications
# To enable email notifications:
# 1. Use a Gmail account
# 2. Enable 2-Factor Authentication
# 3. Generate an App Password: https://myaccount.google.com/apppasswords
# 4. Replace EMAIL_USER with your Gmail address
# 5. Replace EMAIL_PASSWORD with the generated App Password (16 characters)
# 
# See EMAIL_SETUP_GUIDE.md for detailed instructions

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-16-char-app-password

# ===================================
# Frontend URL
# ===================================
FRONTEND_URL=http://localhost:5173

# ===================================
# File Upload Configuration
# ===================================
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# ===================================
# Rate Limiting
# ===================================
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# ===================================
# Session Configuration
# ===================================
SESSION_SECRET=your-session-secret-change-this-in-production

# ===================================
# Amadeus API Configuration (Optional)
# ===================================
# OPTIONAL - For real-time flight data
# Get your API credentials from:
# https://developers.amadeus.com/
# 
# 1. Create a free account
# 2. Create a new app
# 3. Copy API Key and API Secret
# 4. Use 'test' for development, 'production' for live data

AMADEUS_API_KEY=your-amadeus-api-key
AMADEUS_API_SECRET=your-amadeus-api-secret
AMADEUS_ENVIRONMENT=test

# ===================================
# IMPORTANT SECURITY NOTES:
# ===================================
# 
# 1. NEVER commit this file with real credentials to Git
# 2. Copy this file to .env and fill in your actual values
# 3. The .env file is in .gitignore and won't be committed
# 4. Generate strong, unique secrets for production
# 5. Rotate secrets regularly
# 6. Use different credentials for development and production
# 
# ===================================
# SETUP CHECKLIST:
# ===================================
# 
# [ ] MongoDB Atlas cluster created
# [ ] MongoDB connection string added
# [ ] JWT secrets generated and added
# [ ] Email credentials configured (optional)
# [ ] Amadeus API keys added (optional)
# [ ] All secrets are unique and secure
# [ ] .env file is NOT committed to Git
# 
# ===================================
